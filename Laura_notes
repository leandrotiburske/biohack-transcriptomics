rank_kd <- matrix(rank(weight_kd), nrow=nrow(weight_kd))
rank_ko <- matrix(rank(weight_ko), nrow=nrow(weight_ko))
rank_mf <- matrix(rank(weight_mf), nrow=nrow(weight_mf))

# 2. Average the ranks across conditions
average_rank <- (rank_kd + rank_ko + rank_mf) / 3

# 3. Apply your final 0 vs 1 threshold to the consensus ranks
# For example, keeping the top 10% highest ranking edges
