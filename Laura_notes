library(minet)

# 2. Prepare the gene expression data -> filtration and normalisation
Example data
matrix1 
#Orientation: Rows must be Samples, and Columns must be Genes.
colnames(matrix1)

# 3. Step A: Compute the Mutual Information Matrix (MIM)
# This estimates the non-linear relationships between all pairs
mim <- build.mim(matrix1, estimator = "spearman")

# 4. Step B: Run the ARACNe algorithm (DPI Pruning)
# minet will automatically prune the weakest edges using DPI
aracne_net <- minet(mim, method = "aracne")

# 5. Convert the continuous weights into a 0 vs 1 Adjacency Matrix
# If an edge was pruned by ARACNe, its weight is exactly 0. 
# If it survived, it has a weight > 0.
adj_matrix <- ifelse(aracne_net > 0, 1, 0)

# (Optional) Clean up: Ensure the diagonal (self-loops) is set to 0
diag(adj_matrix) <- 0

# Print a small 5x5 chunk of your final 0/1 matrix
print(adj_matrix[1:5, 1:5])

